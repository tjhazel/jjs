<?xml version="1.0" encoding="utf-8"?>
<!--
  API web.config — lives inside ./api (the folder configured as its own
  IIS Application). This is largely what `dotnet publish` generates
  automatically; the version below is the same thing, slightly annotated.

  IMPORTANT: configure ./api as a distinct IIS "Application" under the site
  (not just a sub-folder) in IIS Manager, so this web.config and the
  AspNetCoreModuleV2 handler apply only to requests already routed here,
  and so this app gets its own process per the hostingModel below.
-->
<configuration>
   <location path="." inheritInChildApplications="false">
      <system.webServer>

         <handlers>
            <remove name="aspNetCore" />
            <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
         </handlers>

         <!--
        processPath/arguments: dotnet publish (without --self-contained) produces
        JJS.Api.dll, launched via the dotnet host, NOT a standalone JJS.Api.exe.
        If you instead publish self-contained / with a runtime-specific apphost,
        change processPath to ".\JJS.Api.exe" and drop the arguments attribute.
      -->
         <aspNetCore processPath="dotnet"
                     arguments=".\JJS.Api.dll"
                     stdoutLogEnabled="true"
                     stdoutLogFile=".\logs\stdout"
                     hostingModel="inprocess">
            <environmentVariables>
               <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
            </environmentVariables>
         </aspNetCore>

      </system.webServer>
   </location>
</configuration>