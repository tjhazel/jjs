<?xml version="1.0" encoding="utf-8"?>
<configuration>
   <location path="." inheritInChildApplications="false">
      <system.webServer>

         <!-- Disable default document at root so it doesn't intercept / before rewrite rules fire -->
         <defaultDocument enabled="false" />


         <!-- 1. ASP.NET Core Module handles all requests; app-level routing takes over from there -->
         <handlers>
            <remove name="aspNetCore" />
            <add name="aspNetCore"
                 path="*"
                 verb="*"
                 modules="AspNetCoreModuleV2"
                 resourceType="Unspecified"
                 preCondition="integratedMode" />
         </handlers>

         <!-- 2. .NET Core Application Runtime Pointer -->
         <aspNetCore processPath="E:\web\m9innova\api\JJS.Api.exe"
                     stdoutLogEnabled="true"
                     stdoutLogFile="E:\web\m9innova\logs\stdout"
                     hostingModel="inprocess">
            <environmentVariables>
               <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
            </environmentVariables>
         </aspNetCore>

         <!-- 3. Traffic Routing Rules -->

         <rewrite>
            <rules>

               <!-- Rule A: Everything under /api/ goes to ASP.NET Core -->
               <rule name="BypassApi" stopProcessing="true">
                  <match url=".*" />
                  <conditions>
                     <add input="{URL}" pattern="^/api(/.*)?$" />
                  </conditions>
                  <action type="None" />
               </rule>

               <!-- Rule B: Root rewrite - must come before file/directory checks -->
               <rule name="RootToUi" stopProcessing="true">
                  <match url="^$" />
                  <action type="Rewrite" url="/ui/index.html" />
               </rule>

               <!-- Rule B2: Also catch the literal /index.html the default doc module
                    may have already redirected to, and send it to the right place -->
               <rule name="IndexHtmlToUi" stopProcessing="true">
                  <match url="^index\.html$" />
                  <action type="Rewrite" url="/ui/index.html" />
               </rule>

               <!-- Rule C: Pass through real files -->
               <rule name="ServeExistingFiles" stopProcessing="true">
                  <match url=".*" />
                  <conditions>
                     <add input="{REQUEST_FILENAME}" matchType="IsFile" />
                  </conditions>
                  <action type="None" />
               </rule>

               <!-- Rule D: Pass through real directories -->
               <rule name="ServeExistingDirectories" stopProcessing="true">
                  <match url=".*" />
                  <conditions>
                     <add input="{REQUEST_FILENAME}" matchType="IsDirectory" />
                  </conditions>
                  <action type="None" />
               </rule>

               <!-- Rule E: Next.js shallow route - /about -> /ui/about.html -->
               <rule name="NextJsShallowRoute" stopProcessing="true">
                  <match url="^([^/]+)/?$" />
                  <conditions>
                     <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                     <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                  </conditions>
                  <action type="Rewrite" url="/ui/{R:1}.html" />
               </rule>

               <!-- Rule F: Next.js nested route - /family/123 -> /ui/family/123/index.html -->
               <rule name="NextJsNestedRoute" stopProcessing="true">
                  <match url="^(.+)/?$" />
                  <conditions>
                     <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                     <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                  </conditions>
                  <action type="Rewrite" url="/ui/{R:1}/index.html" />
               </rule>

            </rules>
         </rewrite>


         <!-- 4. Logging and Diagnostics -->
         <tracing>
            <traceFailedRequests>
               <add path="*">
                  <traceAreas>
                     <add provider="ASP" verbosity="Verbose" />
                     <add provider="ASPNET" areas="Infrastructure,Module,Page,AppServices" verbosity="Verbose" />
                     <add provider="WWW Server" areas="Authentication,Security,Filter,StaticFile,CGI,Compression,Cache,RequestNotifications,Module,FastCGI,WebSocket" verbosity="Verbose" />
                  </traceAreas>
                  <failureDefinitions statusCodes="400-599" />
               </add>
            </traceFailedRequests>
         </tracing>
         <httpErrors errorMode="Detailed" existingResponse="PassThrough" />

      </system.webServer>
   </location>
</configuration>