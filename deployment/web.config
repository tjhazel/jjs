<?xml version="1.0" encoding="utf-8"?>
<configuration>
   <location path="." inheritInChildApplications="false">
      <system.webServer>

         <!-- 1. Handle .NET API Triggers Only -->
         <handlers>
            <add name="aspNetCore" path="api/*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
            <add name="aspNetCoreSwagger" path="swagger*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
         </handlers>

         <!-- 2. .NET Core Application Runtime Pointer -->
         <aspNetCore processPath=".\api\JJS.Api.exe" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess">
            <environmentVariables>
               <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
            </environmentVariables>
         </aspNetCore>

         <!-- 3. Traffic Route Management Routing Rules -->
         <rewrite>
            <rules>
               <!-- Rule A: Stop processing if the request is targeting the API or Swagger -->
               <rule name="BypassApi" stopProcessing="true">
                  <match url="^(api|swagger)(/.*)?$" />
                  <action type="None" />
               </rule>

               <!-- Rule B: Direct domain hit (://johnandjeri.com) serves Next.js Main Landing Page -->
               <rule name="RootToUi" stopProcessing="true">
                  <match url="^$" />
                  <action type="Rewrite" url="ui/index.html" />
               </rule>

               <!-- Rule C: Fallback rule for Next.js routing paths (maps /dashboard/ to /ui/dashboard/index.html) -->
               <rule name="NextJsSubfolderRouting" stopProcessing="true">
                  <match url=".*" />
                  <conditions>
                     <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                     <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                  </conditions>
                  <action type="Rewrite" url="ui/{R:0}" />
               </rule>
            </rules>
         </rewrite>

         <!-- 4. Logging & Diagnostics Configuration -->
         <tracing>
            <traceFailedRequests>
               <add path="*">
                  <traceAreas>
                     <add provider="ASP" verbosity="Verbose" />
                     <add provider="ASPNET" areas="Infrastructure,Module,Page,AppServices" verbosity="Verbose" />
                     <add provider="WWW Server" areas="Authentication,Security,Filter,StaticFile,CGI,Compression,Cache,RequestNotifications,Module,FastCGI,WebSocket" verbosity="Verbose" />
                  </traceAreas>
                  <failureDefinitions statusCodes="400-599" />
               </add>
            </traceFailedRequests>
         </tracing>
         <httpErrors errorMode="Detailed" />

      </system.webServer>
   </location>
</configuration>
