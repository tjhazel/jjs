<?xml version="1.0" encoding="utf-8"?>
<configuration>
   <location path="." inheritInChildApplications="false">
   <system.webServer>
      <!-- Completely disables the document engine from altering our route urls -->
      <defaultDocument enabled="false" />

      <!-- 1. ASP.NET Core Module handles all requests; app-level routing takes over from there -->
      <handlers>
         <remove name="aspNetCore" />
         <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <!-- 2. .NET Core Application Runtime Pointer -->
      <aspNetCore processPath=".\api\JJS.Api.exe"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
         <handlerSettings>
            <handlerSetting name="debugFile" value=".\logs\aspnetcore-debug.log" />
            <handlerSetting name="debugLevel" value="FILE,TRACE" />
         </handlerSettings>
         <environmentVariables>
            <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
         </environmentVariables>
      </aspNetCore>
      
      <rewrite>
         <rules>
            <!-- 1. API REVERSE PROXY PASS-THROUGH (DO NOT TOUCH .NET CORE) -->
            <rule name="API Pass-through" stopProcessing="true">
               <match url="^api(.*)" />
               <action type="None" />
            </rule>

            <!-- 2. ROUTE THE BARE DOMAIN TO NEXT.JS BASE ROUTE -->
            <rule name="Clean Domain Root" stopProcessing="true">
               <match url="^$" />
               <!-- Directs traffic internally to the /ui route initialization mapping -->
               <action type="Rewrite" url="ui/" />
            </rule>

            <!-- 3. MAP REMAINING PATHS TO NEXTJS WITHOUT REWRITING FILE NAMES -->
            <rule name="NextJS SSR Router Pass" stopProcessing="true">
               <match url="(.*)" />
               <conditions logicalGrouping="MatchAll">
                  <!-- Verify it is not a physical file payload asset -->
                  <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                  <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                  <!-- Do not intercept .NET application routing hooks -->
                  <add input="{URL}" pattern="^/api" negate="true" />
               </conditions>
               <!-- Proxies the clean paths over to your NextJS sub-application runner -->
               <action type="Rewrite" url="ui/{R:1}" />
            </rule>
         </rules>
      </rewrite>

      <staticContent>
         <remove fileExtension=".json" />
         <mimeMap fileExtension=".json" mimeType="application/json" />
      </staticContent>
   </system.webServer>
   </location>
</configuration>
