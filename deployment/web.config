<?xml version="1.0" encoding="utf-8"?>
<!--
  ROOT web.config — lives at the site root (same level as the ./api and ./ui folders).
  Responsibility: decide, per request, whether IIS should hand off to the API application
  or serve a static file out of ./ui. Does NOT run the ASP.NET Core Module itself —
  that only happens inside ./api/web.config, since /api is configured as its own
  IIS Application in this site.
-->
<configuration>
   <system.webServer>

      <!-- Disable the default document at the root so it doesn't short-circuit
         before the rewrite rules below get a chance to run. -->
      <defaultDocument enabled="false" />

      <rewrite>
         <rules>

            <!-- Rule A: Anything under /api is owned by the API application.
             Because /api is configured as its own IIS Application (pointing at
             ./api with its own web.config + AspNetCoreModuleV2), IIS will already
             route those requests there before URL Rewrite even runs at the site
             level. This rule exists as a safety net / clarity marker and to make
             sure no later rule in this file can ever rewrite an /api request. -->
            <rule name="BypassApi" stopProcessing="true">
               <match url="^api(/.*)?$" />
               <action type="None" />
            </rule>

            <!-- Rule B: Root -> UI shell.
             Request for "/" serves the Next.js export's index page. -->
            <rule name="RootToUi" stopProcessing="true">
               <match url="^$" />
               <action type="Rewrite" url="/ui/index.html" />
            </rule>

            <!-- Rule C: Let real files pass through untouched.
             Covers /ui/* static assets (JS, CSS, images) and anything else
             that physically exists on disk. -->
            <rule name="ServeExistingFiles" stopProcessing="true">
               <match url=".*" />
               <conditions>
                  <add input="{REQUEST_FILENAME}" matchType="IsFile" />
               </conditions>
               <action type="None" />
            </rule>

            <!-- Rule D: Let real directories pass through untouched
             (lets IIS's own default-document handling, if re-enabled
             per-folder, or directory browsing work normally). -->
            <rule name="ServeExistingDirectories" stopProcessing="true">
               <match url=".*" />
               <conditions>
                  <add input="{REQUEST_FILENAME}" matchType="IsDirectory" />
               </conditions>
               <action type="None" />
            </rule>

            <!-- Rule E: Next.js shallow route, e.g. /about -> /ui/about.html
             Only matches a single path segment with no trailing slash content. -->
            <rule name="NextJsShallowRoute" stopProcessing="true">
               <match url="^([^/]+)/?$" />
               <conditions logicalGrouping="MatchAll">
                  <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                  <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
               </conditions>
               <action type="Rewrite" url="/ui/{R:1}.html" />
            </rule>

            <!-- Rule F: Next.js nested route, e.g. /family/123 -> /ui/family/123/index.html
             Covers multi-segment paths, including the placeholder-param pages
             produced for dynamic [id] routes under output: 'export' (e.g.
             /recipe/42 needs to land on the prerendered placeholder shell,
             which fetches the real record client-side). Verify the exact
             exported folder name for each dynamic route (e.g. "placeholder")
             and adjust below if the export doesn't simply mirror the request path. -->
            <rule name="NextJsNestedRoute" stopProcessing="true">
               <match url="^(.+)/?$" />
               <conditions logicalGrouping="MatchAll">
                  <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                  <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
               </conditions>
               <action type="Rewrite" url="/ui/{R:1}/index.html" />
            </rule>

         </rules>
      </rewrite>

      <!-- 4. Logging and Diagnostics -->
      <tracing>
         <traceFailedRequests>
            <add path="*">
               <traceAreas>
                  <add provider="ASP" verbosity="Verbose" />
                  <add provider="ASPNET" areas="Infrastructure,Module,Page,AppServices" verbosity="Verbose" />
                  <add provider="WWW Server" areas="Authentication,Security,Filter,StaticFile,CGI,Compression,Cache,RequestNotifications,Module,FastCGI,WebSocket" verbosity="Verbose" />
               </traceAreas>
               <failureDefinitions statusCodes="400-599" />
            </add>
         </traceFailedRequests>
      </tracing>
      <!--<httpErrors errorMode="Detailed" />
   
       Optional: trim verbose diagnostics in production. Re-enable while debugging. -->
      <httpErrors errorMode="DetailedLocalOnly" />

   </system.webServer>
</configuration>
