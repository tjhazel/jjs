     <div className={classes.overlay} />\n         <Grid container>\n            <Grid item md={6}>\n               <div className={classes.mainFeaturedPostContent}>\n                  <Typography component=\"h1\" variant=\"h3\" color=\"inherit\" gutterBottom>\n                     {props.article.title}\n                  </Typography>\n                  <Typography variant=\"h5\" color=\"inherit\" paragraph>\n                     <div dangerouslySetInnerHTML={{ __html: `${props.article.body}` }} />\n                  </Typography>\n                  \n               </div>\n            </Grid>\n         </Grid>\n      </Paper>\n   )\n\n   return html;\n}\n\nexport default Article;\n","C:\\Users\\jhazeltine\\source\\repos\\jjs\\jjs-web\\src\\Dashboard\\ArticleMain.tsx",[],"C:\\Users\\jhazeltine\\source\\repos\\jjs\\jjs-web\\src\\Dashboard\\ArticleList.tsx",["127"],"C:\\Users\\jhazeltine\\source\\repos\\jjs\\jjs-web\\src\\Dashboard\\ArticleNav.tsx",[],"C:\\Users\\jhazeltine\\source\\repos\\jjs\\jjs-web\\src\\Theme\\Theme.tsx",[],"C:\\Users\\jhazeltine\\source\\repos\\jjs\\jjs-web\\src\\Auth\\AuthProvider.tsx",[],"C:\\Users\\jhazeltine\\source\\repos\\jjs\\jjs-web\\src\\Dashboard\\DataFetcher.ts",["128","129"],"C:\\Users\\jhazeltine\\source\\repos\\jjs\\jjs-web\\src\\Data\\HttpClient.ts",[],"C:\\Users\\jhazeltine\\source\\repos\\jjs\\jjs-web\\src\\Data\\httpClient.ts",[],{"ruleId":"130","severity":1,"message":"131","line":16,"column":10,"nodeType":"132","messageId":"133","endLine":16,"endColumn":28},{"ruleId":"130","severity":1,"message":"134","line":28,"column":19,"nodeType":"132","messageId":"133","endLine":28,"endColumn":26},{"ruleId":"130","severity":1,"message":"135","line":28,"column":28,"nodeType":"132","messageId":"133","endLine":28,"endColumn":38},{"ruleId":"130","severity":1,"message":"131","line":15,"column":12,"nodeType":"132","messageId":"133","endLine":15,"endColumn":30},{"ruleId":"130","severity":1,"message":"134","line":67,"column":21,"nodeType":"132",